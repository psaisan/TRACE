def save_synthetic_dataset(prefix: str, ds: SyntheticDataset):
    """
    Save X, H, y, and metadata.
    """
    np.save(f"{prefix}_X.npy", ds.X)
    np.save(f"{prefix}_H.npy", ds.H)
    np.save(f"{prefix}_y.npy", ds.y)
    with open(f"{prefix}_meta.json", "w") as f:
        json.dump(ds.meta, f, indent=2)


def save_trace_result_summary(path: str, result: Dict[str, Any]):
    with open(path, "w") as f:
        json.dump(result["summary"], f, indent=2)


