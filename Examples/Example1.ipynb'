#!/usr/bin/env python3

"""
TRACE synthetic linear-world toolkit
------------------------------------

Purpose
-------
A single, consistent synthetic-data module built around the same linear-Gaussian
world used in the TRACE paper logic:

    Y -> latent biology B -> observed deployable X and paired modality Z_true
    translator h: X -> Z_hat learned from paired data
    downstream comparison between X and Z_hat across label budgets

This file provides:

1. Core linear-world generation
2. Translator fitting
3. Ready-to-use synthetic dataset presets for distinct TRACE regimes
4. Learning-curve / ARC evaluation utilities
5. Optional plotting
6. Simple example main block

Main user-facing entry points
-----------------------------
- generate_linear_trace_dataset(...)
- generate_reference_regimes(...)
- run_trace_diagnostic(...)

Returned arrays
---------------
X : deployable representation, shape (N, d)
H : translated representation H = h(X), shape (N, p)
y : binary labels, shape (N,)

Optional metadata includes the full world parameters.

Notes
-----
These are controlled synthetic reference regimes, not realistic biological simulators.
They are intended to make TRACE behavior interpretable and reproducible.
"""

import math
import json
from dataclasses import dataclass
from typing import Dict, Any, Optional, Tuple, List

import numpy as np
import matplotlib.pyplot as plt

from sklearn.linear_model import Ridge, LogisticRegression
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import roc_auc_score


# ============================================================
# Utilities
# ============================================================

def make_orthonormal_basis(d: int, r: int, rng: np.random.Generator) -> np.ndarray:
    A = rng.normal(size=(d, r))
    Q, _ = np.linalg.qr(A)
    return Q[:, :r]


def _norm_cdf(x):
    x = np.asarray(x, dtype=float)
    return 0.5 * (1.0 + np.vectorize(math.erf)(x / np.sqrt(2.0)))


def delta2_from_gaussian(mu_vec: np.ndarray, Sigma: np.ndarray) -> float:
    """
    delta^2 = mu^T Sigma^{-1} mu
    """
    return float(mu_vec @ np.linalg.solve(Sigma, mu_vec))


def bayes_auc_from_delta2(delta2: float) -> float:
    """
    For balanced classes with means ??mu and shared covariance Sigma:
        AUC* = Phi( sqrt(2 * delta^2) )
    """
    return float(_norm_cdf(np.sqrt(2.0 * max(delta2, 0.0))))


def make_dense_n_grid(
    n_min: int = 30,
    n_mid: int = 1000,
    n_max: int = 10000,
    n_low: int = 24,
    n_high: int = 8,
) -> np.ndarray:
    low = np.unique(np.round(np.logspace(np.log10(n_min), np.log10(n_mid), n_low)).astype(int))
    high = np.unique(
        np.round(np.logspace(np.log10(max(n_mid + 1, 1200)), np.log10(n_max), n_high)).astype(int)
    )
    return np.unique(np.concatenate([low, high]))


def _gaussian_kernel1d(sigma_pts: float = 1.4, radius: Optional[int] = None) -> np.ndarray:
    if radius is None:
        radius = int(max(2, np.ceil(3 * sigma_pts)))
    x = np.arange(-radius, radius + 1)
    k = np.exp(-0.5 * (x / sigma_pts) ** 2)
    k /= k.sum()
    return k


def _smooth_series_logx(x, y, sigma_pts: float = 1.4, upsample: int = 600):
    """
    Smooth y(x) in log10(x)-space.
    """
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)

    lx = np.log10(x)
    lx_dense = np.linspace(lx.min(), lx.max(), upsample)
    y_dense = np.interp(lx_dense, lx, y)

    k = _gaussian_kernel1d(sigma_pts=sigma_pts)
    pad = len(k) // 2
    y_pad = np.pad(y_dense, (pad, pad), mode="edge")
    y_smooth = np.convolve(y_pad, k, mode="same")[pad:-pad]

    x_smooth = 10 ** lx_dense
    return x_smooth, y_smooth


def _compute_band(stat_mat: np.ndarray, band_mode: str = "std"):
    """
    stat_mat: shape (repeats, n_points)
    band_mode:
      - 'std'  : +- 1 std
      - 'sem'  : +- 1 standard error
      - 'ci95' : +- 1.96 * sem
    """
    mean = stat_mat.mean(axis=0)

    if stat_mat.shape[0] > 1:
        std = stat_mat.std(axis=0, ddof=1)
    else:
        std = np.zeros_like(mean)

    sem = std / np.sqrt(max(1, stat_mat.shape[0]))

    if band_mode == "std":
        band = std
    elif band_mode == "sem":
        band = sem
    elif band_mode == "ci95":
        band = 1.96 * sem
    else:
        raise ValueError("band_mode must be one of: 'std', 'sem', 'ci95'")

    return mean, band, std, sem


def learned_auc_logreg(
    train_feat: np.ndarray,
    ytr: np.ndarray,
    test_feat: np.ndarray,
    yte: np.ndarray,
    C: float = 0.05,
    max_iter: int = 4000,
) -> float:
    """
    Standardized logistic regression -> AUC.
    Robust to near-degenerate cases.
    """
    ytr = np.asarray(ytr).astype(int)
    yte = np.asarray(yte).astype(int)

    if np.unique(ytr).size < 2:
        return 0.5

    sc = StandardScaler(with_mean=True, with_std=True)
    Xtr = sc.fit_transform(train_feat)
    Xte = sc.transform(test_feat)

    clf = LogisticRegression(
        penalty="l2",
        C=C,
        solver="lbfgs",
        max_iter=max_iter,
    )
    clf.fit(Xtr, ytr)
    p = clf.predict_proba(Xte)[:, 1]
    return roc_auc_score(yte, p)


# ============================================================
# Linear-Gaussian world
# ============================================================

def make_biology_aligned_T(m: int, p: int, rng: np.random.Generator, jitter: float = 0.05) -> np.ndarray:
    """
    Create a p x m paired-modality map that is close to identity on biology axes.
    Works for p <= m or p > m.
    """
    T = np.zeros((p, m))
    diag_dim = min(p, m)
    T[:diag_dim, :diag_dim] = np.eye(diag_dim)
    if jitter > 0:
        T = T + jitter * rng.normal(size=(p, m)) / np.sqrt(max(m, 1))
    return T


def sample_world(
    rng: np.random.Generator,
    d: int = 1000,
    m: int = 12,
    p: int = 12,
    r: int = 200,
    sigma_x: float = 1.0,
    sigma_z: float = 0.4,
    lam: float = 8.0,
    biology_noise: float = 1.0,
    T_mode: str = "identity_like",
    T_jitter: float = 0.05,
) -> Dict[str, Any]:
    """
    Balanced binary class Y -> latent biology B -> observed X and paired modality Z_true
    """
    b0 = rng.normal(size=m)
    b0 /= (np.linalg.norm(b0) + 1e-12)

    A = rng.normal(size=(d, m)) / np.sqrt(m)  # biology -> X

    if T_mode == "identity_like":
        T = make_biology_aligned_T(m, p, rng, jitter=T_jitter)
    elif T_mode == "random":
        T = rng.normal(size=(p, m)) / np.sqrt(m)
    else:
        raise ValueError("T_mode must be 'identity_like' or 'random'")

    Q = make_orthonormal_basis(d, r, rng)  # nuisance basis in X

    return dict(
        d=d,
        m=m,
        p=p,
        r=r,
        sigma_x=sigma_x,
        sigma_z=sigma_z,
        lam=lam,
        biology_noise=biology_noise,
        b0=b0,
        A=A,
        T=T,
        Q=Q,
        T_mode=T_mode,
        T_jitter=T_jitter,
    )


def sample_XZ_from_world(params: Dict[str, Any], rng: np.random.Generator, n: int):
    d, m, p, r = params["d"], params["m"], params["p"], params["r"]
    sigma_x, sigma_z, lam = params["sigma_x"], params["sigma_z"], params["lam"]
    bn = params["biology_noise"]
    b0, A, T, Q = params["b0"], params["A"], params["T"], params["Q"]

    Y = rng.integers(0, 2, size=n)
    s = 2 * Y - 1

    xi = rng.normal(size=(n, m)) * bn
    B = s[:, None] * b0[None, :] + xi

    Z_true = B @ T.T + rng.normal(size=(n, p)) * sigma_z

    ncoef = rng.normal(size=(n, r))
    eps = rng.normal(size=(n, d)) * sigma_x
    X = B @ A.T + lam * (ncoef @ Q.T) + eps

    return X, Z_true, Y


def fit_translator_ridge(X_pair: np.ndarray, Z_pair: np.ndarray, alpha: float = 1.0):
    model = Ridge(alpha=alpha, fit_intercept=True)
    model.fit(X_pair, Z_pair)

    def h(X):
        return model.predict(X)

    return model, h


# ============================================================
# Gaussian params for ceiling calculations
# ============================================================

def gaussian_params_for_X(params: Dict[str, Any]) -> Tuple[np.ndarray, np.ndarray]:
    b0, A, Q = params["b0"], params["A"], params["Q"]
    bn, lam, sigma_x = params["biology_noise"], params["lam"], params["sigma_x"]
    d = params["d"]

    muX = A @ b0
    SigmaX = (bn ** 2) * (A @ A.T) + (lam ** 2) * (Q @ Q.T) + (sigma_x ** 2) * np.eye(d)
    return muX, SigmaX


def gaussian_params_for_Zhat(
    muX: np.ndarray, SigmaX: np.ndarray, translator_model: Ridge
) -> Tuple[np.ndarray, np.ndarray]:
    W = translator_model.coef_  # shape: (p, d)
    muZ = W @ muX
    SigmaZ = W @ SigmaX @ W.T
    return muZ, SigmaZ


# ============================================================
# Synthetic regime presets
# ============================================================

def _regime_defaults(regime: str) -> Dict[str, Any]:
    """
    Named presets derived from the same canonical linear world.
    """
    base = dict(
        d=1000,
        m=12,
        p=12,
        r=200,
        sigma_x=1.0,
        sigma_z=0.4,
        lam=8.0,
        biology_noise=1.0,
        T_mode="identity_like",
        T_jitter=0.05,
        n_pair=12000,
        ridge_alpha=1.0,
    )

    presets = {
        # Flagship regime: H helps at low n because X is nuisance-entangled.
        "sample_efficiency": dict(
            lam=8.0,
            sigma_z=0.4,
            T_mode="identity_like",
            T_jitter=0.05,
            n_pair=12000,
            ridge_alpha=1.0,
        ),

        # Stronger nuisance / larger dimensional burden. H remains useful over practical n.
        "persistent_advantage": dict(
            d=1500,
            p=10,
            r=300,
            lam=12.0,
            sigma_z=0.35,
            T_mode="identity_like",
            T_jitter=0.03,
            n_pair=16000,
            ridge_alpha=0.7,
        ),

        # X is already fairly learnable, so H adds little.
        "no_advantage": dict(
            d=500,
            p=12,
            r=120,
            lam=1.5,
            sigma_z=0.35,
            T_mode="identity_like",
            T_jitter=0.02,
            n_pair=12000,
            ridge_alpha=1.0,
        ),

        # Translator is weak / lossy: noisy paired modality, fewer paired samples, random map.
        "lossy_translation": dict(
            d=1000,
            p=8,
            r=200,
            lam=5.0,
            sigma_z=1.2,
            T_mode="random",
            T_jitter=0.20,
            n_pair=1500,
            ridge_alpha=2.0,
        ),

        # Same world family, but easier to confound through site-specific nuisance coding.
        # For now we expose the same generator; users can extend with site-aware splits.
        "confounded_like": dict(
            d=1200,
            p=12,
            r=250,
            lam=9.0,
            sigma_z=0.5,
            T_mode="identity_like",
            T_jitter=0.07,
            n_pair=12000,
            ridge_alpha=1.0,
        ),
    }

    if regime not in presets:
        raise ValueError(f"Unknown regime '{regime}'. Available: {list(presets.keys())}")

    out = dict(base)
    out.update(presets[regime])
    return out


# ============================================================
# User-facing synthetic-data generation
# ============================================================

@dataclass
class SyntheticDataset:
    X: np.ndarray
    H: np.ndarray
    y: np.ndarray
    meta: Dict[str, Any]
    world: Optional[Dict[str, Any]] = None
    translator_model: Optional[Ridge] = None
    pair_data: Optional[Dict[str, np.ndarray]] = None


def generate_linear_trace_dataset(
    regime: str = "sample_efficiency",
    n_samples: int = 4000,
    seed: int = 7,
    return_world: bool = False,
    return_pair_data: bool = False,
    **overrides,
) -> SyntheticDataset:
    """
    Generate a synthetic TRACE dataset from a single canonical linear-Gaussian world.

    Parameters
    ----------
    regime : str
        One of:
            - 'sample_efficiency'
            - 'persistent_advantage'
            - 'no_advantage'
            - 'lossy_translation'
            - 'confounded_like'
    n_samples : int
        Number of labeled synthetic samples to return.
    seed : int
        RNG seed.
    return_world : bool
        If True, include world dictionary.
    return_pair_data : bool
        If True, include paired data used to train the translator.
    **overrides
        Any world/preset parameter overrides.

    Returns
    -------
    SyntheticDataset
        Contains X, H, y, meta, and optionally world/pair_data.
    """
    rng = np.random.default_rng(seed)

    params = _regime_defaults(regime)
    params.update(overrides)

    n_pair = int(params.pop("n_pair"))
    ridge_alpha = float(params.pop("ridge_alpha"))

    world = sample_world(rng, **params)

    # Paired data to train translator
    Xp, Zp, _ = sample_XZ_from_world(world, rng, n=n_pair)
    translator_model, h = fit_translator_ridge(Xp, Zp, alpha=ridge_alpha)

    # Labeled synthetic dataset
    X, _, y = sample_XZ_from_world(world, rng, n=n_samples)
    H = h(X)

    muX, SigmaX = gaussian_params_for_X(world)
    aucX_star = bayes_auc_from_delta2(delta2_from_gaussian(muX, SigmaX))

    muH, SigmaH = gaussian_params_for_Zhat(muX, SigmaX, translator_model)
    aucH_star = bayes_auc_from_delta2(delta2_from_gaussian(muH, SigmaH))

    meta = dict(
        regime=regime,
        n_samples=int(n_samples),
        seed=int(seed),
        n_pair=int(n_pair),
        ridge_alpha=float(ridge_alpha),
        aucX_star=float(aucX_star),
        aucH_star=float(aucH_star),
        d=int(world["d"]),
        m=int(world["m"]),
        p=int(world["p"]),
        r=int(world["r"]),
        sigma_x=float(world["sigma_x"]),
        sigma_z=float(world["sigma_z"]),
        lam=float(world["lam"]),
        biology_noise=float(world["biology_noise"]),
        T_mode=str(world["T_mode"]),
        T_jitter=float(world["T_jitter"]),
    )

    pair_data = None
    if return_pair_data:
        pair_data = {"X_pair": Xp, "Z_pair": Zp}

    return SyntheticDataset(
        X=X,
        H=H,
        y=y,
        meta=meta,
        world=world if return_world else None,
        translator_model=translator_model,
        pair_data=pair_data,
    )


def generate_reference_regimes(
    n_samples: int = 4000,
    seed: int = 7,
) -> Dict[str, SyntheticDataset]:
    """
    Generate all main reference regimes with consistent structure.
    """
    regimes = [
        "sample_efficiency",
        "persistent_advantage",
        "no_advantage",
        "lossy_translation",
    ]
    out = {}
    for i, regime in enumerate(regimes):
        out[regime] = generate_linear_trace_dataset(
            regime=regime,
            n_samples=n_samples,
            seed=seed + i,
        )
    return out


# ============================================================
# TRACE-style diagnostic workflow on X, H, y
# ============================================================

def run_trace_diagnostic(
    X: np.ndarray,
    H: np.ndarray,
    y: np.ndarray,
    n_grid: Optional[np.ndarray] = None,
    repeats: int = 64,
    train_fraction: float = 0.7,
    seed: int = 123,
    C_X: float = 0.03,
    C_H: float = 1.0,
) -> Dict[str, Any]:
    """
    Evaluate learning curves for X and H across label budgets.
    Uses a fixed train/test split, then repeatedly subsamples training labels.

    Parameters
    ----------
    X : ndarray, shape (N, d_x)
    H : ndarray, shape (N, d_h)
    y : ndarray, shape (N,)
    n_grid : array-like
        Label budgets.
    repeats : int
        Repeated subsamples per budget.
    train_fraction : float
        Fraction of samples allocated to training pool.
    seed : int
        RNG seed.
    C_X, C_H : float
        Logistic regression C values for X and H branches.

    Returns
    -------
    dict
        Learning-curve result with ARC summaries.
    """
    rng = np.random.default_rng(seed)

    X = np.asarray(X, dtype=float)
    H = np.asarray(H, dtype=float)
    y = np.asarray(y).astype(int)

    N = X.shape[0]
    if H.shape[0] != N or y.shape[0] != N:
        raise ValueError("X, H, and y must have the same number of rows.")

    if n_grid is None:
        n_grid = make_dense_n_grid(n_min=30, n_mid=min(1000, max(100, N // 2)), n_max=max(300, int(0.7 * N)))
    n_grid = np.asarray(n_grid, dtype=int)

    idx = rng.permutation(N)
    n_train = int(round(train_fraction * N))
    tr_idx = idx[:n_train]
    te_idx = idx[n_train:]

    Xtr_full, Xte = X[tr_idx], X[te_idx]
    Htr_full, Hte = H[tr_idx], H[te_idx]
    ytr_full, yte = y[tr_idx], y[te_idx]

    max_train = Xtr_full.shape[0]
    n_grid = n_grid[n_grid <= max_train]
    if len(n_grid) == 0:
        raise ValueError("n_grid contains no values <= size of training split.")

    aucX = np.zeros((repeats, len(n_grid)))
    aucH = np.zeros((repeats, len(n_grid)))

    for j, nlab in enumerate(n_grid):
        for rep in range(repeats):
            sub = rng.choice(max_train, size=nlab, replace=False)

            Xtr = Xtr_full[sub]
            Htr = Htr_full[sub]
            ytr = ytr_full[sub]

            aucX[rep, j] = learned_auc_logreg(Xtr, ytr, Xte, yte, C=C_X)
            aucH[rep, j] = learned_auc_logreg(Htr, ytr, Hte, yte, C=C_H)

    arc = aucH - aucX
    meanX = aucX.mean(axis=0)
    meanH = aucH.mean(axis=0)
    meanARC = arc.mean(axis=0)

    summary = summarize_arc(n_grid, meanARC, meanX, meanH)

    return {
        "n": n_grid,
        "aucX": aucX,
        "aucH": aucH,
        "arc": arc,
        "meanX": meanX,
        "meanH": meanH,
        "meanARC": meanARC,
        "summary": summary,
        "settings": {
            "repeats": int(repeats),
            "train_fraction": float(train_fraction),
            "seed": int(seed),
            "C_X": float(C_X),
            "C_H": float(C_H),
        },
    }


def summarize_arc(
    n_grid: np.ndarray,
    meanARC: np.ndarray,
    meanX: np.ndarray,
    meanH: np.ndarray,
    low_n_fraction: float = 0.25,
    eps_zero: float = 0.02,
    eps_persistent: float = 0.05,
) -> Dict[str, Any]:
    """
    Simple decision-oriented ARC summary.
    """
    n_grid = np.asarray(n_grid)
    meanARC = np.asarray(meanARC)
    meanX = np.asarray(meanX)
    meanH = np.asarray(meanH)

    k_low = max(1, int(np.ceil(low_n_fraction * len(n_grid))))
    low_arc = float(meanARC[:k_low].mean())
    tail_arc = float(meanARC[-k_low:].mean())
    peak_arc = float(meanARC.max())
    best_n = int(n_grid[np.argmax(meanARC)])

    crossover_n = None
    pos = np.where(meanARC <= 0)[0]
    if len(pos) > 0:
        crossover_n = int(n_grid[pos[0]])

    if low_arc > eps_persistent and tail_arc > eps_persistent:
        classification = "persistent_advantage"
        recommendation = "Translated representation appears useful across the studied range; improving the translator may be worthwhile."
    elif low_arc > eps_persistent and abs(tail_arc) <= eps_zero:
        classification = "sample_efficiency_gain"
        recommendation = "Translated representation mainly improves learnability at low label budgets; collecting more labels may reduce the gap."
    elif abs(low_arc) <= eps_zero and abs(tail_arc) <= eps_zero:
        classification = "no_advantage"
        recommendation = "Translation adds little practical value over the studied range; using the original representation may suffice."
    elif tail_arc < -eps_zero:
        classification = "lossy_or_harmful_translation"
        recommendation = "Translated representation appears to discard useful signal at larger sample sizes; direct modeling on the original representation is likely preferable."
    else:
        classification = "mixed_or_ambiguous"
        recommendation = "ARC pattern is mixed; inspect learning curves, uncertainty bands, and possible confounding or model mismatch."

    return {
        "classification": classification,
        "recommendation": recommendation,
        "low_label_arc": low_arc,
        "tail_arc": tail_arc,
        "peak_arc": peak_arc,
        "best_n": best_n,
        "crossover_n": crossover_n,
        "final_auc_X": float(meanX[-1]),
        "final_auc_H": float(meanH[-1]),
    }


# ============================================================
# Plotting
# ============================================================

def plot_learning_curves(
    result: Dict[str, Any],
    title: Optional[str] = None,
    band_mode: str = "std",
    smooth_sigma_pts_mean: float = 1.4,
    smooth_sigma_pts_band: float = 1.8,
    show_raw_points: bool = False,
    show_raw_mean: bool = True,
    show_smoothed_mean: bool = True,
    show_band: bool = True,
    figsize: Tuple[float, float] = (8.4, 5.4),
):
    n = np.asarray(result["n"], dtype=float)
    aucX = np.asarray(result["aucX"], dtype=float)
    aucH = np.asarray(result["aucH"], dtype=float)

    meanX, bandX, _, _ = _compute_band(aucX, band_mode=band_mode)
    meanH, bandH, _, _ = _compute_band(aucH, band_mode=band_mode)

    xsX, meanX_s = _smooth_series_logx(n, meanX, sigma_pts=smooth_sigma_pts_mean, upsample=700)
    xsH, meanH_s = _smooth_series_logx(n, meanH, sigma_pts=smooth_sigma_pts_mean, upsample=700)

    _, bandX_s = _smooth_series_logx(n, bandX, sigma_pts=smooth_sigma_pts_band, upsample=700)
    _, bandH_s = _smooth_series_logx(n, bandH, sigma_pts=smooth_sigma_pts_band, upsample=700)

    bandX_s = np.maximum(bandX_s, 0.0)
    bandH_s = np.maximum(bandH_s, 0.0)

    fig, ax = plt.subplots(1, 1, figsize=figsize, constrained_layout=True)

    if show_raw_points:
        rng = np.random.default_rng(12345)
        for j, nj in enumerate(n):
            jitter_x_X = nj * np.exp(rng.normal(0.0, 0.020, size=aucX.shape[0]))
            jitter_x_H = nj * np.exp(rng.normal(0.0, 0.020, size=aucH.shape[0]))
            ax.scatter(jitter_x_H, aucH[:, j], s=14, alpha=0.10)
            ax.scatter(jitter_x_X, aucX[:, j], s=14, alpha=0.10)

    if show_raw_mean:
        ax.semilogx(n, meanH, marker="o", markersize=3.0, linewidth=1.1, alpha=0.45, label=r"$AUC_n(H)$ raw mean")
        ax.semilogx(n, meanX, marker="o", markersize=3.0, linewidth=1.1, alpha=0.45, label=r"$AUC_n(X)$ raw mean")

    if show_band:
        ax.fill_between(xsH, meanH_s - bandH_s, meanH_s + bandH_s, alpha=0.18, label=rf"$H$ {band_mode} band")
        ax.fill_between(xsX, meanX_s - bandX_s, meanX_s + bandX_s, alpha=0.18, label=rf"$X$ {band_mode} band")

    if show_smoothed_mean:
        ax.semilogx(xsH, meanH_s, linewidth=3.0, label=r"$AUC_n(H)$ smoothed")
        ax.semilogx(xsX, meanX_s, linewidth=3.0, label=r"$AUC_n(X)$ smoothed")

    ax.set_xlabel(r"labeled samples $n$ (log scale)")
    ax.set_ylabel("AUC")
    ax.set_ylim(0.45, 1.0)

    if title is not None:
        ax.set_title(title)

    ax.legend(frameon=False, fontsize=9)
    return fig


def plot_arc_curve(
    result: Dict[str, Any],
    title: Optional[str] = None,
    band_mode: str = "std",
    smooth_sigma_pts_mean: float = 1.4,
    smooth_sigma_pts_band: float = 1.8,
    figsize: Tuple[float, float] = (8.4, 5.0),
):
    n = np.asarray(result["n"], dtype=float)
    arc = np.asarray(result["arc"], dtype=float)

    meanARC, bandARC, _, _ = _compute_band(arc, band_mode=band_mode)
    xs, mean_s = _smooth_series_logx(n, meanARC, sigma_pts=smooth_sigma_pts_mean, upsample=700)
    _, band_s = _smooth_series_logx(n, bandARC, sigma_pts=smooth_sigma_pts_band, upsample=700)
    band_s = np.maximum(band_s, 0.0)

    fig, ax = plt.subplots(1, 1, figsize=figsize, constrained_layout=True)
    ax.fill_between(xs, mean_s - band_s, mean_s + band_s, alpha=0.20, label=rf"ARC {band_mode} band")
    ax.semilogx(xs, mean_s, linewidth=3.0, label=r"$ARC(n)=AUC_n(H)-AUC_n(X)$")
    ax.axhline(0.0, linestyle="--", linewidth=1.3)

    ax.set_xlabel(r"labeled samples $n$ (log scale)")
    ax.set_ylabel("ARC")
    if title is not None:
        ax.set_title(title)
    ax.legend(frameon=False, fontsize=9)
    return fig


